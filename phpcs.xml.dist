<?xml version="1.0"?>
<ruleset name="Total Mail Queue">
    <description>
        Adopts the full WordPress coding standard. Sniffs that need authorial
        work or that are scheduled for follow-up phases are explicitly excluded
        below — they will be re-enabled as the corresponding phase lands.
    </description>

    <!-- What to scan -->
    <file>total-mail-queue.php</file>
    <file>total-mail-queue-options.php</file>
    <file>total-mail-queue-smtp.php</file>

    <!-- What to skip -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/lib/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>

    <!-- CLI behavior -->
    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg name="cache" value=".phpcs.cache"/>
    <arg value="ps"/>

    <!-- Full WordPress ruleset, then strategically exclude what later phases
         will address so phpcbf-driven F1 can pass clean. -->
    <rule ref="WordPress">

        <!-- Properties on external classes (DOMDocument, PHPMailer, …) are
             part of those libraries' APIs and cannot be renamed by us. We only
             enforce snake_case on variables we own. -->
        <exclude name="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase"/>

        <!-- ============================================================
             Phase F4 — Authorial work
             ============================================================ -->
        <exclude name="Squiz.Commenting.FileComment"/>
        <exclude name="Squiz.Commenting.ClassComment"/>
        <exclude name="Squiz.Commenting.FunctionComment"/>
        <exclude name="Squiz.Commenting.VariableComment"/>
        <exclude name="Generic.Commenting.DocComment"/>
        <!-- Yoda conditions — adopting the WP convention requires touching
             every comparison; reserved for the documentation/style finalization
             phase since it's a stylistic rewrite, not auto-fixable. -->
        <exclude name="WordPress.PHP.YodaConditions.NotYoda"/>

        <!-- ============================================================
             Won't fix — codebase decisions
             ============================================================ -->
        <!-- The plugin's main entry file is named after the slug, not the
             class it loosely contains. -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <!-- WP_TMQ_PHPMailer-Config and friends in queue headers don't follow
             WP hook naming because they're not WP hooks. -->
        <exclude name="WordPress.NamingConventions.ValidHookName"/>
        <!-- The file is structured as procedural functions plus one helper
             class (wp_tmq_Log_Table extends WP_List_Table); separating them
             is out of scope. -->
        <exclude name="Universal.Files.SeparateFunctionsFromOO"/>
        <!-- Long lines in inline notice / FAQ HTML are intentional. -->
        <exclude name="Generic.Files.LineLength"/>
        <!-- The wp_tmq_Log_Table class is intentionally lower-case to match
             the plugin's wp_tmq_ function prefix; renaming is a public-API
             break we're not taking. -->
        <exclude name="WordPress.NamingConventions.ValidFunctionName.FunctionNameInvalid"/>
        <exclude name="PEAR.NamingConventions.ValidClassName.Invalid"/>
        <exclude name="PEAR.NamingConventions.ValidClassName.StartWithCapital"/>
        <!-- Reserved-keyword param names on legacy callbacks. -->
        <exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames"/>
        <!-- The plugin intentionally registers a custom cron interval; the
             sniff flags any code that touches `cron_schedules`. -->
        <exclude name="WordPress.WP.CronInterval.ChangeDetected"/>
        <!-- We assign to `$wp_filter['pre_wp_mail']` to clone-and-restore the
             filter chain inside the cron loop; that's the documented technique
             for safely calling wp_mail() while owning a pre_wp_mail filter. -->
        <exclude name="WordPress.WP.GlobalVariablesOverride.Prohibited"/>
    </rule>

    <!-- Text domain consistency -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="total-mail-queue"/>
            </property>
        </properties>
    </rule>

    <!-- All public functions / hook callbacks must be prefixed -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="wp_tmq"/>
                <element value="WP_TMQ"/>
            </property>
        </properties>
    </rule>

    <!-- PHP version compatibility for the runtime supported by the plugin.
         Plugin header declares PHP 7.4+ as the minimum. -->
    <config name="testVersion" value="7.4-"/>
    <rule ref="PHPCompatibilityWP"/>

    <!-- Minimum supported WP version (matches readme.txt "Requires at least") -->
    <config name="minimum_wp_version" value="5.9"/>
</ruleset>
