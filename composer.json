{
    "name": "rpgmem/total-mail-queue",
    "description": "Queue outgoing emails, manage SMTP accounts with daily/monthly limits, and get alerts if your site sends too many emails.",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "brain/monkey": "^2.6",
        "phpmailer/phpmailer": "^6.9",
        "phpunit/phpunit": "^10.5"
    },
    "autoload-dev": {
        "psr-4": {
            "TMQ\\Tests\\": "tests/",
            "TMQ\\Tests\\Support\\": "tests/Support/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=unit",
        "test:integration": "phpunit --testsuite=integration"
    },
    "config": {
        "sort-packages": true
    }
}
